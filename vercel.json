{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "prisma generate && next build",
  "env": {
    "SKIP_ENV_VALIDATION": "1"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
